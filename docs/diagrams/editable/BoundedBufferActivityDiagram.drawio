                <mxCell id="100" value="&lt;span&gt;&lt;b&gt;Condition variables&lt;/b&gt; (&lt;code style=&quot;&quot; data-index-in-node=&quot;33&quot; data-path-to-node=&quot;2,0,0&quot;&gt;notFull&lt;/code&gt;/&lt;code style=&quot;&quot; data-index-in-node=&quot;41&quot; data-path-to-node=&quot;2,0,0&quot;&gt;notEmpty&lt;/code&gt;) prevent busy-waiting by suspending threads until state changes.&lt;/span&gt;" style="shape=note;strokeWidth=2;fontSize=10;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;fontFamily=Verdana;verticalAlign=middle;" parent="6" vertex="1">
