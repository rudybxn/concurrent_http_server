                <mxCell id="20" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Scheduling Policies:&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#666600&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;line-height: 100%;&quot;&gt;First-Come-First Served (FCFS)&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot;&gt;&lt;ul style=&quot;padding-left: 10px;&quot;&gt;&lt;li&gt;First-In-First-Out (FIFO) logic&lt;/li&gt;&lt;li&gt;Remove head element&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot;&gt;Smallest-File-First (SFF)&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot;&gt;&lt;ul style=&quot;padding-left: 10px;&quot;&gt;&lt;li&gt;Buffer is a priority queue (key = file size)&lt;/li&gt;&lt;li&gt;Remove min(file size)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;strokeWidth=2;fontSize=10;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;fontFamily=Verdana;align=left;spacingLeft=10;" parent="5" vertex="1">
